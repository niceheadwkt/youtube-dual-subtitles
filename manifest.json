{
  "manifest_version": 3,
  "name": "YouTube 雙語字幕助手 (YouTube Dual Subtitles)",
  "version": "1.0.0",
  "description": "在 YouTube 影片播放時同步顯示雙語字幕，支援多國語言設定與自訂字型大小。",
  "permissions": [
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "https://*.youtube.com/*",
    "https://translate.googleapis.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.youtube.com/watch*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "style.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
